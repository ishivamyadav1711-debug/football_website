generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites    Favorite[]
  predictions  Prediction[]
  notifications Notification[]
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // 'team', 'player', 'league'
  itemId    Int      // ID from API-Football
  createdAt DateTime @default(now())

  @@unique([userId, type, itemId])
}

model Prediction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  matchId   Int      // ID from API-Football
  homeScore Int
  awayScore Int
  createdAt DateTime @default(now())

  @@unique([userId, matchId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // 'goal', 'red_card', 'match_start'
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
